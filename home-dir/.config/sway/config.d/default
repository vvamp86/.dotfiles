#####################
# Default Variables #
#####################
# Logo key. Use Mod1 for Alt.
set $mod Mod4

# Add Vim key support
set $left   h
set $down   j
set $up     k
set $right  l

# Set default terminal emulator
set $term alacritty

# Application launcher
set $launcher rofi -modi drun -show drun -config ~/.config/rofi/rofidmenu.rasi

# Application menu
set $menu nwg-drawer

# Power Menu
set $powermenu ~/.config/sway/scripts/powermenu

# swaylock comand
set $swaylock ~/.config/sway/scripts/swaylock.sh

########################
# Application Defaults #
########################
# Browsers
# primary & secondary
set $primary_browser /usr/bin/brave
set $secondary_browser /usr/bin/librewolf

# Music
# primary & secondary
set $primary_music env LD_PRELOAD=/usr/lib/spotify-adblock.so spotify
set $secondary_music youtube-music

# PDF Viewer
# primary & secondary
set $primary_pdf_viewer zathura
set $secondary_pdf_viewer sioyek

# File Explorers
set $primary_file_explorer pcmanfm
set $secondary_file_explorer $term -T sway_yazi -e yazi

# Note Platform:
set $primary_notes obsidian
set $secondary_notes $term -T sway_neovim -e nvim

# Messaging
set $primary_messaging vesktop
set $secondary_messaging evolution
set $tertiary_messaging slack


##############
# Workspaces #
##############
    # Workspace bindings are using bindcode instead of bindsym for better Azerty compatibility.
    # https://github.com/EndeavourOS-Community-Editions/sway/pull/81
    # Use wev to find keycodes for setting up other bindings this way.

    # Define names for default workspaces for which we configure key bindings later on.
    # We use variables to avoid repeating the names in multiple places.
    set $ws1    "1"
    set $ws2    "2"
    set $ws3    "3"
    set $ws4    "4"
    set $ws5    "5"
    set $ws6    "6"
    set $ws7    "7"
    set $ws8    "8"
    set $ws9    "9"
    set $ws10   "10"

